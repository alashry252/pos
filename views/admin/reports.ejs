<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<style>
    /* =========================================
       ✨ تصميم شاشة التقارير والرقابة الفائقة (Enterprise Financial UI)
       ========================================= */
    body {
        background-color: #f8fafc;
        font-family: 'Inter', 'Noto Sans Arabic', sans-serif;
    }

    /* كروت الإحصائيات الفخمة */
    .report-stat-card {
        background: #ffffff;
        border: 1px solid rgba(226, 232, 240, 0.8);
        border-radius: 1.5rem;
        padding: 1.75rem;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.01), 0 2px 4px -1px rgba(0,0,0,0.01);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
    }
    .report-stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05), 0 10px 10px -5px rgba(0, 0, 0, 0.02);
        border-color: #cbd5e1;
    }
    .report-stat-card::before {
        content: ''; position: absolute; top: -50px; right: -50px;
        width: 130px; height: 130px;
        background: radial-gradient(circle, var(--icon-color-alpha, rgba(99, 102, 241, 0.05)) 0%, rgba(255,255,255,0) 70%);
        border-radius: 50%;
    }
    .report-stat-icon {
        width: 56px; height: 56px;
        border-radius: 1rem;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.5rem;
        color: var(--icon-color, #4f46e5);
        background: var(--icon-bg, #f0fdf4);
        box-shadow: inset 0 2px 4px rgba(255,255,255,0.4);
    }

    /* التبويبات الفخمة (Cashier Navigation Tabs) */
    .employee-tab-btn {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 1rem;
        padding: 1rem 1.25rem;
        width: 100%;
        text-align: right;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 0.75rem;
    }
    .employee-tab-btn:hover {
        background: #f8fafc;
        border-color: #cbd5e1;
        transform: translateX(-4px);
    }
    .employee-tab-btn.active {
        background: linear-gradient(135deg, #4f46e5 0%, #3b82f6 100%);
        color: white !important;
        border-color: transparent;
        box-shadow: 0 10px 15px -3px rgba(79, 70, 229, 0.3);
    }
    .employee-tab-btn.active .text-dark {
        color: white !important;
    }
    .employee-tab-btn.active .text-muted {
        color: rgba(255, 255, 255, 0.7) !important;
    }

    /* صندوق إغلاق الوردية والدرج الذهبي (Safe Drawer closing box) */
    .safe-closing-box {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        color: white;
        border-radius: 1.5rem;
        padding: 2rem;
        box-shadow: 0 20px 25px -5px rgba(15, 23, 42, 0.15);
        position: relative;
        overflow: hidden;
    }
    .safe-closing-box::after {
        content: ''; position: absolute; bottom: -20px; left: -20px;
        width: 120px; height: 120px;
        background: radial-gradient(circle, rgba(16, 185, 129, 0.15) 0%, rgba(255,255,255,0) 70%);
        border-radius: 50%;
    }

    .closing-cash-display {
        font-size: 2.25rem;
        font-weight: 900;
        color: #10b981;
        text-shadow: 0 0 15px rgba(16, 185, 129, 0.3);
    }

    /* الخط الزمني وسجل الحضور */
    .audit-badge {
        font-size: 0.8rem;
        padding: 0.5rem 1rem;
        border-radius: 50rem;
        font-weight: 700;
    }

    /* البطاقات التوضيحية التفصيلية */
    .audit-card {
        background: #ffffff;
        border: 1px solid rgba(226, 232, 240, 0.8);
        border-radius: 1.5rem;
        padding: 1.5rem;
    }
</style>

<div class="main-content-wrapper">
    <main class="container-fluid px-3 px-lg-5 py-4 fade-in-up">
        
        <!-- الترويسة الرئيسية -->
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 pb-3 border-bottom">
            <div>
                <h3 class="fw-black text-dark mb-1 d-flex align-items-center gap-2">
                    <div class="bg-primary bg-opacity-10 text-primary p-2 rounded-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                        <i class="fa-solid fa-file-invoice-dollar fs-5"></i>
                    </div>
                    التقارير المالية والرقابة الشاملة
                </h3>
                <p class="text-muted small mb-0 ms-5" style="margin-right: 3.2rem;">رقابة مبيعات وحركة الخزنة والورديات لموظفي الكاشير والتحليلات المالية التراكمية</p>
            </div>
            <button class="btn btn-light rounded-pill fw-bold border px-4 py-2 shadow-xs transition-all hover-lift" onclick="window.print()">
                <i class="fa-solid fa-print me-1"></i> طباعة التقرير العام
            </button>
        </div>

        <!-- ١. لوحة مؤشرات الأداء والمالية العلوية (Financial Stat Cards) -->
        <div class="row g-4 mb-4">
            <!-- الدخل اليومي -->
            <div class="col-sm-6 col-xl-3">
                <div class="report-stat-card" style="--icon-color: #10b981; --icon-bg: rgba(16, 185, 129, 0.1); --icon-color-alpha: rgba(16, 185, 129, 0.15)">
                    <div class="d-flex align-items-center gap-3">
                        <div class="report-stat-icon"><i class="fa-solid fa-sack-dollar"></i></div>
                        <div>
                            <p class="text-muted small fw-bold mb-1">صافي الدخل اليومي</p>
                            <h3 class="fw-black mb-0 text-dark"><%= stats.todaySales.toLocaleString('ar-EG') %> <span class="fs-6 text-muted fw-normal">ج.م</span></h3>
                        </div>
                    </div>
                </div>
            </div>

            <!-- إجمالي دخل المطعم (التراكمي) -->
            <div class="col-sm-6 col-xl-3">
                <div class="report-stat-card" style="--icon-color: #4f46e5; --icon-bg: rgba(79, 70, 229, 0.1); --icon-color-alpha: rgba(79, 70, 229, 0.15)">
                    <div class="d-flex align-items-center gap-3">
                        <div class="report-stat-icon"><i class="fa-solid fa-vault"></i></div>
                        <div>
                            <p class="text-muted small fw-bold mb-1">إجمالي دخل المطعم التراكمي</p>
                            <h3 class="fw-black mb-0 text-dark"><%= stats.lifetimeIncome.toLocaleString('ar-EG') %> <span class="fs-6 text-muted fw-normal">ج.م</span></h3>
                        </div>
                    </div>
                </div>
            </div>

            <!-- حضور الموظفين اليوم -->
            <div class="col-sm-6 col-xl-3">
                <div class="report-stat-card" style="--icon-color: #06b6d4; --icon-bg: rgba(6, 182, 212, 0.1); --icon-color-alpha: rgba(6, 182, 212, 0.15)">
                    <div class="d-flex align-items-center gap-3">
                        <div class="report-stat-icon"><i class="fa-solid fa-user-check"></i></div>
                        <div>
                            <p class="text-muted small fw-bold mb-1">حضور الموظفين اليوم</p>
                            <h3 class="fw-black mb-0 text-dark"><%= stats.presentCount %> <span class="fs-6 text-muted fw-normal">حاضر</span></h3>
                        </div>
                    </div>
                </div>
            </div>

            <!-- إجمالي الموظفين -->
            <div class="col-sm-6 col-xl-3">
                <div class="report-stat-card" style="--icon-color: #8b5cf6; --icon-bg: rgba(139, 92, 246, 0.1); --icon-color-alpha: rgba(139, 92, 246, 0.15)">
                    <div class="d-flex align-items-center gap-3">
                        <div class="report-stat-icon"><i class="fa-solid fa-users"></i></div>
                        <div>
                            <p class="text-muted small fw-bold mb-1">إجمالي الموظفين بالنظام</p>
                            <h3 class="fw-black mb-0 text-dark"><%= stats.totalEmployees %> <span class="fs-6 text-muted fw-normal">موظف</span></h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ٢. قسم التبويبات الفردية للموظفين (Employee Shifts & safe Auditing) -->
        <h5 class="fw-black text-dark mb-3 mt-5 d-flex align-items-center gap-2">
            <i class="fa-solid fa-cash-register text-primary"></i> مركز رقابة الكاشير وحركة الخزنة والورديات
        </h5>

        <div class="row g-4">
            <!-- قائمة الموظفين (التبويبات الجانبية) -->
            <div class="col-lg-4 col-xl-3">
                <div class="card border-0 shadow-sm rounded-4 p-3 bg-white">
                    <p class="small text-muted fw-bold mb-3 border-bottom pb-2"><i class="fa-solid fa-list me-1"></i> اختر موظف لعرض تقريره</p>
                    
                    <div class="nav flex-column nav-pills" id="employeesTabList" role="tablist" aria-orientation="vertical">
                        <% employeeReports.forEach((rep, index) => { %>
                            <button class="employee-tab-btn border shadow-none <%= index === 0 ? 'active' : '' %>" 
                                    id="tab-btn-<%= rep.user._id %>" 
                                    data-bs-toggle="pill" 
                                    data-bs-target="#tab-content-<%= rep.user._id %>" 
                                    type="button" 
                                    role="tab" 
                                    aria-selected="<%= index === 0 ? 'true' : 'false' %>">
                                
                                <div class="d-flex align-items-center gap-3">
                                    <div class="avatar-circle fs-6 fw-bold border" style="width: 36px; height: 36px; border-radius: 8px;">
                                        <%= rep.user.name.charAt(0).toUpperCase() %>
                                    </div>
                                    <div class="text-start">
                                        <div class="fw-bold text-dark small"><%= rep.user.name %></div>
                                        <div class="text-muted" style="font-size: 0.75rem;"><%= rep.user.role === 'admin' ? 'مدير نظام' : 'موظف كاشير' %></div>
                                    </div>
                                </div>

                                <div>
                                    <% if (rep.isPresent) { %>
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25" style="font-size: 0.7rem;"><i class="fa-solid fa-circle text-success fs-xs me-1"></i>حاضر</span>
                                    <% } else { %>
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25" style="font-size: 0.7rem;">غائب</span>
                                    <% } %>
                                </div>
                            </button>
                        <% }) %>
                    </div>
                </div>
            </div>

            <!-- محتويات التبويبات الفردية للموظف -->
            <div class="col-lg-8 col-xl-9">
                <div class="tab-content" id="employeesTabContent">
                    <% employeeReports.forEach((rep, index) => { %>
                        <div class="tab-pane fade <%= index === 0 ? 'show active' : '' %>" 
                             id="tab-content-<%= rep.user._id %>" 
                             role="tabpanel">
                            
                            <div class="row g-4">
                                <!-- بطاقة ملخص الحضور والوردية ودرج الخزنة للموظف -->
                                <div class="col-md-5">
                                    <div class="safe-closing-box h-100 d-flex flex-column justify-content-between">
                                        <div>
                                            <div class="d-flex justify-content-between align-items-start mb-3">
                                                <div>
                                                    <span class="text-white-50 small d-block">كود الحساب الرقمي</span>
                                                    <span class="badge bg-white bg-opacity-20 text-white font-monospace"><i class="fa-solid fa-hashtag me-1 opacity-50"></i><%= rep.user.accountId %></span>
                                                </div>
                                                
                                                <% if (rep.isPresent) { %>
                                                    <span class="audit-badge bg-success text-white"><i class="fa-solid fa-circle-check me-1"></i> حاضر بالوردية</span>
                                                <% } else { %>
                                                    <span class="audit-badge bg-danger text-white"><i class="fa-solid fa-circle-xmark me-1"></i> غائب اليوم</span>
                                                <% } %>
                                            </div>

                                            <h4 class="fw-black text-white mb-4 mt-2"><%= rep.user.name %></h4>

                                            <!-- تفاصيل الحضور والانصراف الذكية -->
                                            <div class="border-top border-white border-opacity-10 pt-3 mb-4">
                                                <div class="row g-2">
                                                    <div class="col-6 border-start border-white border-opacity-10 ps-2">
                                                        <span class="text-white-50 small d-block"><i class="fa-regular fa-clock me-1"></i> أول حضور اليوم</span>
                                                        <span class="fw-bold text-white"><%= rep.loginTime || 'لم يحضر بعد' %></span>
                                                    </div>
                                                    <div class="col-6 ps-2">
                                                        <span class="text-white-50 small d-block"><i class="fa-solid fa-arrow-right-from-bracket me-1"></i> آخر انصراف</span>
                                                        <span class="fw-bold text-white"><%= rep.logoutTime || 'لم ينصرف بعد' %></span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- إجمالي قفل الخزنة والدرج الكاش للموظف -->
                                        <div class="bg-white bg-opacity-5 p-3 rounded-4 border border-white border-opacity-10 mt-3">
                                            <span class="text-white-50 small fw-bold d-block mb-1"><i class="fa-solid fa-cash-register me-1 text-success"></i> صافي إغلاق الخزنة للموظف (قفل الدرج)</span>
                                            <h2 class="closing-cash-display mb-0"><%= rep.safeClosing.toLocaleString('ar-EG') %> <span class="fs-5 text-white fw-normal font-sans">ج.م</span></h2>
                                            <small class="text-white-50 d-block mt-1 font-monospace" style="font-size: 0.75rem;">حساب الدرج الكاش: المبيعات كاش (<%= rep.cashSalesVal %>ج) - مرتجعات كاش (<%= rep.cashRefundsVal %>ج)</small>
                                        </div>
                                    </div>
                                </div>

                                <!-- بطاقة إحصائيات المعاملات المبيعات والمرتجع للموظف اليوم -->
                                <div class="col-md-7">
                                    <div class="audit-card bg-white h-100">
                                        <h6 class="fw-black text-dark mb-4 pb-2 border-bottom"><i class="fa-solid fa-chart-pie text-primary me-1"></i> إحصائيات مبيعات وحركات الخزنة اليومية</h6>
                                        
                                        <div class="row g-3 mb-4">
                                            <!-- إجمالي المبيعات كاش -->
                                            <div class="col-6">
                                                <div class="p-3 bg-light rounded-3 border">
                                                    <span class="small text-muted fw-bold d-block mb-1 text-success"><i class="fa-solid fa-money-bill-wave me-1"></i> المدفوعات نقدي (كاش)</span>
                                                    <h5 class="fw-black text-dark mb-0"><%= rep.cashSalesVal.toLocaleString('ar-EG') %> <span class="small fw-normal text-muted">ج</span></h5>
                                                </div>
                                            </div>

                                            <!-- إجمالي المبيعات فيزا -->
                                            <div class="col-6">
                                                <div class="p-3 bg-light rounded-3 border">
                                                    <span class="small text-muted fw-bold d-block mb-1 text-primary"><i class="fa-solid fa-credit-card me-1"></i> مبيعات بالبطاقة (فيزا)</span>
                                                    <h5 class="fw-black text-dark mb-0"><%= rep.cardSalesVal.toLocaleString('ar-EG') %> <span class="small fw-normal text-muted">ج</span></h5>
                                                </div>
                                            </div>

                                            <!-- المبيعات الناجحة الكلية -->
                                            <div class="col-6">
                                                <div class="p-3 bg-success bg-opacity-5 rounded-3 border border-success border-opacity-10">
                                                    <span class="small text-success-emphasis fw-bold d-block mb-1"><i class="fa-solid fa-circle-check me-1"></i> العمليات الناجحة الكلية</span>
                                                    <h5 class="fw-black text-success mb-0"><%= rep.totalSalesVal.toLocaleString('ar-EG') %> <span class="small fw-bold font-monospace">(<%= rep.salesCount %> ط)</span></h5>
                                                </div>
                                            </div>

                                            <!-- إجمالي المرتجعات المسجلة -->
                                            <div class="col-6">
                                                <div class="p-3 bg-danger bg-opacity-5 rounded-3 border border-danger border-opacity-10">
                                                    <span class="small text-danger-emphasis fw-bold d-block mb-1"><i class="fa-solid fa-rotate-left me-1"></i> المرتجعات المسجلة اليوم</span>
                                                    <h5 class="fw-black text-danger mb-0"><%= rep.totalRefundsVal.toLocaleString('ar-EG') %> <span class="small fw-bold font-monospace">(<%= rep.refundsCount %> م)</span></h5>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="alert alert-info border-info border-opacity-25 bg-info bg-opacity-5 p-3 rounded-3 mb-0 d-flex gap-2">
                                            <i class="fa-solid fa-info mt-1 text-info fs-5"></i>
                                            <small class="fw-bold text-info-emphasis lh-sm">
                                                جميع الأرقام المحاسبية المعروضة بالملخص أعلاه تخضع للتدقيق اللحظي ومباشرة من قاعدة البيانات، وتمثل الوردية النشطة من الساعة 12:00 صباحاً لليوم الجاري.
                                            </small>
                                        </div>
                                    </div>
                                </div>

                                <!-- جدول حركة الخزنة التفصيلي (تفاصيل فواتير ومرتجعات الموظف اليوم) -->
                                <div class="col-12 mt-4">
                                    <div class="audit-card bg-white">
                                        <h6 class="fw-black text-dark mb-4 pb-2 border-bottom d-flex justify-content-between align-items-center">
                                            <span><i class="fa-solid fa-receipt text-primary me-1"></i> جدول حركة الخزنة والعمليات بالتفصيل لليوم</span>
                                            <span class="badge bg-light text-dark border font-monospace" style="font-size: 0.75rem;">إجمالي العمليات اليوم: <%= rep.transactions.length %> عملية</span>
                                        </h6>

                                        <div class="table-responsive">
                                            <table class="table align-middle mb-0 custom-table">
                                                <thead class="bg-light text-muted small text-uppercase">
                                                    <tr>
                                                        <th class="ps-3 py-3 border-0 rounded-start-3">رقم الفاتورة</th>
                                                        <th class="border-0">نوع العملية</th>
                                                        <th class="border-0">طريقة الدفع</th>
                                                        <th class="border-0">نوع الطلب</th>
                                                        <th class="border-0">وقت التنفيذ</th>
                                                        <th class="border-0">القيمة المالية</th>
                                                        <th class="border-0 rounded-end-3 text-center">الحالة</th>
                                                    </tr>
                                                </thead>
                                                <tbody class="border-top-0">
                                                    <% if (rep.transactions.length === 0) { %>
                                                        <tr>
                                                            <td colspan="7" class="text-center py-5 text-muted">
                                                                <div class="text-muted mb-2"><i class="fa-solid fa-ban fs-1 opacity-25"></i></div>
                                                                <h6 class="fw-bold">لا توجد عمليات مبيعات أو مرتجعات مسجلة للموظف اليوم.</h6>
                                                                <p class="small mb-0 opacity-75">عندما يبدأ الموظف بالعمل، ستظهر تفاصيل عملياته وحركة خزنته هنا فوراً.</p>
                                                            </td>
                                                        </tr>
                                                    <% } else { %>
                                                        <% rep.transactions.forEach(t => { %>
                                                            <tr class="border-bottom">
                                                                <td class="ps-3 fw-bold text-primary font-monospace"><i class="fa-solid fa-hashtag opacity-50 me-1"></i><%= t.orderNumber %></td>
                                                                <td class="fw-bold small text-dark"><%= t.type === 'sale' ? 'فاتورة مبيعات صادر' : 'إرجاع فاتورة (مرتجع)' %></td>
                                                                <td class="text-muted small fw-bold"><i class="fa-solid <%= t.paymentMethod.includes('نقدي') ? 'fa-money-bill text-success' : 'fa-credit-card text-primary' %> me-1 opacity-75"></i><%= t.paymentMethod %></td>
                                                                <td class="text-muted small fw-bold"><%= t.orderType %></td>
                                                                <td class="text-dark small fw-bold font-monospace"><i class="fa-regular fa-clock text-muted me-1"></i><%= t.time %></td>
                                                                <td class="fw-black <%= t.type === 'refund' ? 'text-danger' : 'text-dark' %>">
                                                                    <%= t.type === 'refund' ? '-' : '+' %><%= t.amount.toLocaleString('ar-EG') %> <span class="small font-sans fw-bold">ج.م</span>
                                                                </td>
                                                                <td class="text-center">
                                                                    <span class="badge <%= t.badgeClass %> px-3 py-2 rounded-pill fw-bold" style="font-size: 0.75rem;">
                                                                        <%= t.statusText %>
                                                                    </span>
                                                                </td>
                                                            </tr>
                                                        <% }) %>
                                                    <% } %>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>

    </main>
</div>

<%- include('../partials/footer') %>
