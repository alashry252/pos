<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<link rel="stylesheet" href="/css/pos.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>


<div class="main-content-wrapper">
    <main class="container-fluid px-2 px-lg-3 py-3">
        
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="fw-black text-dark mb-0"><i class="fa-solid fa-desktop text-primary me-2"></i>نقطة البيع (POS)</h4>
            <button class="btn btn-dark rounded-pill fw-bold px-4 shadow-sm" data-bs-toggle="modal" data-bs-target="#previousOrdersModal">
                <i class="fa-solid fa-clock-rotate-left me-2"></i> الفواتير السابقة
            </button>
        </div>

        <div class="pos-wrapper fade-in-up">
            
            <div class="products-section shadow-sm border rounded-4 bg-white d-flex flex-column overflow-hidden flex-grow-1">
                <div class="p-3 border-bottom bg-white">
                    <div class="row g-2 align-items-center">
                        <div class="col-md-5">
                            <div class="input-group shadow-none rounded-pill overflow-hidden bg-light">
                                <span class="input-group-text bg-transparent border-0"><i class="fa-solid fa-magnifying-glass text-muted"></i></span>
                                <input type="text" id="posSearch" class="form-control border-0 bg-transparent shadow-none" placeholder="بحث سريع..." autocomplete="off">
                            </div>
                        </div>
                        <div class="col-md-7">
                            <div class="d-flex gap-2 overflow-x-auto pb-1" id="categoryList" style="scrollbar-width: none;">
                                <button class="btn btn-sm btn-primary rounded-pill fw-bold px-3 category-pill active" onclick="filterCategory('الكل', this)">الكل</button>
                                <% 
                                    const categories = [...new Set(products.map(p => p.category))];
                                    categories.forEach(cat => { 
                                %>
                                    <button class="btn btn-sm btn-light rounded-pill fw-bold px-3 text-muted border category-pill" onclick="filterCategory('<%= cat %>', this)"><%= cat %></button>
                                <% }) %>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="p-3 flex-grow-1 overflow-y-auto" style="background: #fcfcfc;">
                    <div class="products-grid" id="productsGrid">
                        <% products.forEach(p => { %>
                            <div class="pos-card" 
                                 data-id="<%= p._id %>" 
                                 data-name="<%= p.name %>" 
                                 data-price="<%= p.price %>" 
                                 data-stock="<%= p.quantity %>"
                                 data-category="<%= p.category %>"
                                 data-sku="<%= p.sku %>"
                                 onclick="handleAddToCart(this)">
                                
                                <div class="d-flex justify-content-between align-items-start">
                                    <span class="card-price"><%= p.price %><small class="text-muted fs-6">ج</small></span>
                                    <span class="stock-indicator <%= p.quantity <= 5 ? 'low' : '' %>"><%= p.quantity %> ق</span>
                                </div>
                                <div class="card-title mt-2"><%= p.name %></div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>

            <div class="cart-section shadow-sm border rounded-4 bg-white d-flex flex-column overflow-hidden" style="width: 400px;">
                <div class="p-3 border-bottom d-flex justify-content-between align-items-center bg-white">
                    <h6 class="fw-black mb-0 text-dark">الفاتورة الحالية</h6>
                    <button class="btn btn-sm btn-outline-danger rounded-pill fw-bold border-0" onclick="confirmClearCart()">
                        <i class="fa-solid fa-trash-can"></i> إفراغ
                    </button>
                </div>

                <div class="flex-grow-1 overflow-y-auto p-2" style="background: #f8fafc;">
                    <div id="cartItemsContainer"></div>
                    
                    <div id="emptyCartMsg" class="text-center py-5">
                        <i class="fa-solid fa-receipt fs-1 text-muted opacity-25 mb-2"></i>
                        <p class="text-muted fw-bold small">لا توجد منتجات مضافة</p>
                    </div>
                </div>

                <div class="p-3 bg-white border-top shadow-sm">
                    <div class="row g-2 mb-3 bg-light p-2 rounded-3">
                        <div class="col-6">
                            <label class="small text-muted fw-bold mb-1">طريقة الدفع</label>
                            <select class="form-select form-select-sm border-0 shadow-none fw-bold" id="paymentMethod">
                                <option value="cash">نقدي (كاش)</option>
                                <option value="card">بطاقة بنكية</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="small text-muted fw-bold mb-1">الخصم (ج.م)</label>
                            <input type="number" id="extraDiscount" class="form-control form-control-sm border-0 fw-bold text-danger" value="0" min="0" oninput="calculateTotals()">
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mb-1 px-1">
                        <span class="text-muted fw-bold small">الإجمالي الفرعي:</span>
                        <span id="subTotalDisplay" class="fw-bold">0 ج</span>
                    </div>
                    
                    <div class="d-flex justify-content-between align-items-center mt-2 p-2 bg-dark rounded-3 text-white">
                        <span class="fw-bold fs-5">المطلوب دفعه</span>
                        <span id="grandTotalDisplay" class="fw-black fs-4 text-warning">0 ج</span>
                    </div>
                    
                    <button class="btn btn-success w-100 py-3 rounded-3 mt-2 fw-black fs-5 shadow-sm" id="payBtn" onclick="processOrder()">
                        دفع وتأكيد <i class="fa-solid fa-check-circle ms-1"></i>
                    </button>
                </div>
            </div>
        </div>
    </main>
</div>

<div class="modal fade" id="previousOrdersModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-header border-bottom-0 bg-light p-4">
                <h5 class="modal-title fw-black"><i class="fa-solid fa-file-invoice me-2 text-primary"></i>سجل الفواتير الأخيرة</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 custom-table">
                        <thead class="bg-light text-muted small">
                            <tr>
                                <th class="ps-4 py-3">رقم الفاتورة</th>
                                <th>التاريخ والوقت</th>
                                <th>الكاشير</th>
                                <th>الإجمالي</th>
                                <th class="text-center pe-4">إجراءات</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (typeof orders !== 'undefined' && orders.length > 0) { %>
                                <% orders.forEach(order => { %>
                                    <tr>
                                        <td class="ps-4 fw-bold text-primary"><i class="fa-solid fa-hashtag opacity-50 me-1"></i><%= order.orderNumber %></td>
                                        <td class="small text-muted fw-bold" dir="ltr"><%= new Date(order.createdAt).toLocaleString('ar-EG') %></td>
                                        <td class="small"><span class="badge bg-secondary bg-opacity-10 text-secondary border px-2"><%= order.cashierName %></span></td>
                                        <td class="fw-black text-success fs-6"><%= order.totalAmount %> ج.م</td>
                                        <td class="text-center pe-4">
                                            <div class="d-flex justify-content-center gap-2">
                                                <button class="btn btn-sm btn-light border rounded-pill shadow-sm" onclick="viewOrderDetails('<%= order._id %>')" title="عرض التفاصيل">
                                                    <i class="fa-solid fa-eye text-dark"></i>
                                                </button>
                                                <button class="btn btn-sm btn-dark rounded-pill shadow-sm" onclick="printOldReceipt('<%= order._id %>')" title="طباعة الفاتورة">
                                                    <i class="fa-solid fa-print"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">
                                        <i class="fa-solid fa-receipt fs-1 mb-3 opacity-25"></i>
                                        <h6>لا توجد أي فواتير مسجلة في النظام حتى الآن.</h6>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    // 🧠 حقن الفواتير السابقة في الجافاسكريبت لتسهيل البحث عنها وطباعتها
    const PREVIOUS_ORDERS = <%- JSON.stringify(locals.orders || []).replace(/</g, '\\u003c') %>;
    // ==========================================
    // 🧠 محرك الكاشير المبسط 
    // ==========================================
    let cart = [];

    function handleAddToCart(element) {
        const product = { id: element.dataset.id, name: element.dataset.name, price: parseFloat(element.dataset.price), stock: parseInt(element.dataset.stock) };
        const existing = cart.find(i => i.id === product.id);
        
        if (existing) {
            if (existing.qty >= product.stock) return Swal.fire({ icon: 'warning', title: 'تنبيه', text: 'الكمية نفذت من المخزن', timer: 1000, showConfirmButton: false });
            existing.qty++;
        } else {
            cart.push({ ...product, qty: 1 });
        }
        renderCart();
    }

    function updateQty(id, delta) {
        const item = cart.find(i => i.id === id);
        if (!item) return;
        if (delta > 0 && item.qty >= item.stock) return;
        item.qty += delta;
        if (item.qty <= 0) cart = cart.filter(i => i.id !== id);
        renderCart();
    }

    function renderCart() {
        const container = document.getElementById('cartItemsContainer');
        const emptyMsg = document.getElementById('emptyCartMsg');
        
        if (cart.length === 0) {
            container.innerHTML = '';
            emptyMsg.classList.remove('d-none');
            calculateTotals();
            return;
        }

        emptyMsg.classList.add('d-none');
        container.innerHTML = cart.map(item => `
            <div class="cart-item-row d-flex justify-content-between align-items-center shadow-sm">
                <div style="flex: 1; padding-left: 10px;">
                    <div class="fw-bold text-dark" style="font-size: 0.85rem;">${item.name}</div>
                    <div class="text-muted" style="font-size: 0.75rem;">${item.price} ج × ${item.qty}</div>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <div class="fw-black text-primary">${(item.price * item.qty).toFixed(0)} ج</div>
                    <div class="qty-control d-flex align-items-center gap-1">
                        <button class="qty-btn" onclick="updateQty('${item.id}', -1)"><i class="fa-solid fa-minus fs-xs"></i></button>
                        <span class="fw-bold small px-1">${item.qty}</span>
                        <button class="qty-btn" onclick="updateQty('${item.id}', 1)"><i class="fa-solid fa-plus fs-xs"></i></button>
                    </div>
                </div>
            </div>
        `).join('');

        calculateTotals();
    }

    function calculateTotals() {
        const subTotal = cart.reduce((sum, item) => sum + (item.price * item.qty), 0);
        const discount = parseFloat(document.getElementById('extraDiscount').value) || 0;
        const grandTotal = Math.max(0, subTotal - discount); 
        document.getElementById('subTotalDisplay').innerText = subTotal.toFixed(0) + ' ج';
        document.getElementById('grandTotalDisplay').innerText = grandTotal.toFixed(0) + ' ج';
    }

    // فلترة وبحث
    const searchInput = document.getElementById('posSearch');
    let currentCategory = 'الكل';
    if(searchInput) { searchInput.addEventListener('input', applyFilters); }

    function filterCategory(cat, btn) {
        currentCategory = cat;
        document.querySelectorAll('.category-pill').forEach(p => {
            p.classList.remove('btn-primary', 'active'); p.classList.add('btn-light', 'text-muted');
        });
        btn.classList.remove('btn-light', 'text-muted'); btn.classList.add('btn-primary', 'active');
        applyFilters();
    }

    function applyFilters() {
        const term = searchInput.value.toLowerCase();
        document.querySelectorAll('.pos-card').forEach(card => {
            const matchSearch = card.dataset.name.toLowerCase().includes(term) || card.dataset.sku.toLowerCase().includes(term);
            const matchCat = currentCategory === 'الكل' || card.dataset.category === currentCategory;
            card.style.display = (matchSearch && matchCat) ? 'flex' : 'none';
        });
    }

    function confirmClearCart() {
        if (cart.length > 0) {
            cart = [];
            document.getElementById('extraDiscount').value = 0;
            renderCart();
        }
    }

    // ==========================================
    // 🖨️ محرك الطباعة الشامل (آمن 100%)
    // ==========================================
    
    // دالة توليد الفاتورة (تقبل فاتورة قديمة، أو تطبع السلة الحالية)
    function generateReceiptHTML(historicOrder = null) {
        const date = historicOrder ? new Date(historicOrder.createdAt).toLocaleString('ar-EG') : new Date().toLocaleString('ar-EG');
        const total = historicOrder ? historicOrder.totalAmount : document.getElementById('grandTotalDisplay').innerText.replace(' ج', '');
        const discount = historicOrder ? (historicOrder.subTotal - historicOrder.totalAmount) : (document.getElementById('extraDiscount').value || 0);
        const orderNumber = historicOrder ? historicOrder.orderNumber : 'INV-NEW';
        
        const itemsToPrint = historicOrder ? historicOrder.items : cart;

        let itemsHtml = itemsToPrint.map(i => {
            const quantity = i.quantity || i.qty; // دعم الفاتورة القديمة (quantity) والجديدة (qty)
            return `
                <tr style="border-bottom: 1px dashed #ccc;">
                    <td style="padding: 5px 0; text-align: right; font-size: 13px; font-weight: bold;">${i.name}</td>
                    <td style="padding: 5px 0; text-align: center;">${quantity}</td>
                    <td style="padding: 5px 0; text-align: left;">${(i.price * quantity).toFixed(0)}</td>
                </tr>
            `;
        }).join('');

        return `
            <div style="width: 80mm; padding: 10px; font-family: 'Courier New', Courier, monospace; color: #000; direction: rtl;">
                <div style="text-align: center; border-bottom: 2px dashed #000; padding-bottom: 10px; margin-bottom: 10px;">
                    <h2 style="margin: 0; font-size: 22px; font-weight: 900;">Nexus POS</h2>
                    <p style="margin: 5px 0; font-size: 12px; font-weight: bold;">رقم الفاتورة: ${orderNumber}</p>
                    <p style="margin: 0; font-size: 12px;">${date}</p>
                </div>
                <table style="width: 100%; font-size: 14px; margin-bottom: 10px; border-collapse: collapse;">
                    <thead>
                        <tr style="border-bottom: 2px solid #000;">
                            <th style="text-align: right; padding-bottom: 5px;">الصنف</th>
                            <th style="text-align: center; padding-bottom: 5px;">الكمية</th>
                            <th style="text-align: left; padding-bottom: 5px;">القيمة</th>
                        </tr>
                    </thead>
                    <tbody>${itemsHtml}</tbody>
                </table>
                <div style="border-top: 2px dashed #000; padding-top: 10px; font-size: 14px; font-weight: bold;">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                        <span>الخصم:</span><span>${discount} ج.م</span>
                    </div>
                    <div style="display: flex; justify-content: space-between; font-size: 20px; font-weight: 900; border-top: 2px solid #000; padding-top: 5px;">
                        <span>الإجمالي:</span><span>${total} ج.م</span>
                    </div>
                </div>
                <div style="text-align: center; font-size: 12px; margin-top: 20px;">
                    <p style="margin: 0; font-weight: bold;">شكراً لزيارتكم!</p>
                </div>
            </div>
        `;
    }

    // 🖨️ طباعة الفاتورة (الحالية أو القديمة)
    function printReceipt(orderData = null) {
        if(!orderData && cart.length === 0) return Swal.fire('تنبيه', 'لا توجد منتجات', 'warning');
        
        const receiptHTML = generateReceiptHTML(orderData);
        
        const iframe = document.createElement('iframe');
        iframe.style.display = 'none';
        document.body.appendChild(iframe);
        
        iframe.contentWindow.document.open();
        iframe.contentWindow.document.write('<html><head><title>Print Receipt</title></head><body onload="window.print(); window.close();">' + receiptHTML + '</body></html>');
        iframe.contentWindow.document.close();
        
        setTimeout(() => { document.body.removeChild(iframe); }, 1500);
    }

    // 📄 تحميل PDF (الحالية أو القديمة)
    function downloadPDF(orderData = null) {
        if(!orderData && cart.length === 0) return Swal.fire('تنبيه', 'لا توجد منتجات', 'warning');
        
        const receiptHTML = generateReceiptHTML(orderData);
        const container = document.createElement('div');
        container.innerHTML = receiptHTML;
        
        const opt = {
            margin: 5,
            filename: `Invoice_${new Date().getTime()}.pdf`,
            image: { type: 'jpeg', quality: 0.98 },
            html2canvas: { scale: 2, useCORS: true },
            jsPDF: { unit: 'mm', format: [80, 200], orientation: 'portrait' } 
        };
        
        html2pdf().set(opt).from(container).save();
    }

    // 👁️ عرض تفاصيل فاتورة سابقة
    function viewOrderDetails(orderId) {
        const order = PREVIOUS_ORDERS.find(o => o._id === orderId);
        if(!order) return;

        let itemsTr = order.items.map(i => `
            <tr>
                <td class="text-end fw-bold">${i.name}</td>
                <td class="text-center"><span class="badge bg-light text-dark border">${i.quantity}</span></td>
                <td class="text-start fw-bold text-success">${(i.price * i.quantity)} ج</td>
            </tr>
        `).join('');

        Swal.fire({
            title: `<span class="fs-5">فاتورة: ${order.orderNumber}</span>`,
            html: `
                <div class="text-muted small mb-3">تاريخ: ${new Date(order.createdAt).toLocaleString('ar-EG')} | بواسطة: ${order.cashierName}</div>
                <table class="table table-sm table-bordered align-middle">
                    <thead class="table-light"><tr><th class="text-end">الصنف</th><th>الكمية</th><th class="text-start">الإجمالي</th></tr></thead>
                    <tbody>${itemsTr}</tbody>
                </table>
                <h4 class="text-danger fw-black mt-3">الإجمالي النهائي: ${order.totalAmount} ج.م</h4>
            `,
            width: '500px',
            showCloseButton: true,
            showConfirmButton: true,
            confirmButtonText: '<i class="fa-solid fa-print"></i> طباعة هذه الفاتورة',
            confirmButtonColor: '#212529',
        }).then((result) => {
            if (result.isConfirmed) {
                printReceipt(order);
            }
        });
    }

    // ==========================================
    // 🚀 تنفيذ عملية البيع
    // ==========================================
    async function processOrder() {
        if (cart.length === 0) return Swal.fire('تنبيه', 'السلة فارغة', 'warning');
        
        const btn = document.getElementById('payBtn');
        btn.disabled = true;
        btn.innerHTML = '<div class="spinner-border spinner-border-sm"></div> جاري التنفيذ...';

        const orderData = {
            cart,
            paymentMethod: document.getElementById('paymentMethod').value,
            discount: parseFloat(document.getElementById('extraDiscount').value) || 0,
            subTotal: parseFloat(document.getElementById('subTotalDisplay').innerText),
            totalAmount: parseFloat(document.getElementById('grandTotalDisplay').innerText)
        };

        try {
            const res = await fetch('/admin/pos/process', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(orderData)
            });
            const data = await res.json();
            
            if (data.success) {
                // توليد الفاتورة للطباعة الفورية قبل تفريغ السلة
                const receiptHTML = generateReceiptHTML(); 
                
                Swal.fire({
                    title: 'تم الدفع بنجاح!',
                    text: 'هل تريد طباعة الفاتورة؟',
                    icon: 'success',
                    showCancelButton: true,
                    confirmButtonText: '<i class="fa-solid fa-print"></i> طباعة الفاتورة',
                    cancelButtonText: 'طلب جديد',
                    confirmButtonColor: '#10b981'
                }).then((result) => {
                    if (result.isConfirmed) {
                        const iframe = document.createElement('iframe');
                        iframe.style.display = 'none';
                        document.body.appendChild(iframe);
                        iframe.contentWindow.document.open();
                        iframe.contentWindow.document.write('<html><head><title>Print</title></head><body onload="window.print(); window.close();">' + receiptHTML + '</body></html>');
                        iframe.contentWindow.document.close();
                    }
                    setTimeout(() => { window.location.reload(); }, 500); 
                });
            } else {
                throw new Error(data.message);
            }
        } catch (e) {
            Swal.fire('خطأ', e.message, 'error');
            btn.disabled = false;
            btn.innerHTML = 'دفع وتأكيد <i class="fa-solid fa-check-circle ms-1"></i>';
        }
    }
</script>

<%- include('../partials/footer') %>