    // دالة استدعاء طباعة الفواتير الذكية (التقسيم المزدوج في Electron أو التراجع للوضع التقليدي)
    function executeTriplePrinting(order) {
        const isElectron = window.process && window.process.versions && window.process.versions.electron;

        if (isElectron) {
            try {
                const { ipcRenderer } = window.require('electron');
                const kitchenPrinter = localStorage.getItem('kitchenPrinter') || '';
                const cashierPrinter = localStorage.getItem('cashierPrinter') || '';

                const kitchenHTML = generateTicketKitchenHTML(order);
                const cashierHTML = generateTicketCashierHTML(order);

                // 1. طباعة صامتة لبون المطبخ (الداخلية)
                ipcRenderer.invoke('print-silent', kitchenHTML, kitchenPrinter)
                    .then(res => {
                        if (!res.success) console.error('Kitchen printing error:', res.error);
                    })
                    .catch(err => console.error(err));

                // 2. طباعة صامتة لبون الكاشير (الخارجية)
                ipcRenderer.invoke('print-silent', cashierHTML, cashierPrinter)
                    .then(res => {
                        if (!res.success) console.error('Cashier printing error:', res.error);
                    })
                    .catch(err => console.error(err));

            } catch (err) {
                console.error('Electron IPC silent printing failed, falling back to browser printing...', err);
                executeFallbackPrinting(order);
            }
        } else {
            executeFallbackPrinting(order);
        }
    }

    // دالة الطباعة الاحتياطية عبر iframe (في حالة المتصفح العادي)
    function executeFallbackPrinting(order) {
        const printContainer = document.getElementById('printFrameContainer');
        printContainer.innerHTML = ''; // تفريغ القديم

        const iframe = document.createElement('iframe');
        iframe.style.position = 'absolute';
        iframe.style.width = '0px';
        iframe.style.height = '0px';
        iframe.style.border = 'none';
        
        printContainer.appendChild(iframe);

        const doc = iframe.contentWindow.document;
        doc.open();
        doc.write(generateTripleReceiptsHTML(order));
        doc.close();

        // الانتظار قليلاً للتأكد من تحميل الخطوط والتنسيقات ثم استدعاء الطباعة
        setTimeout(() => {
            iframe.contentWindow.focus();
            iframe.contentWindow.print();
        }, 600);
    }

    // طباعة فاتورة قديمة بالنمط الثلاثي أيضاً
    function printOldReceipt(orderId) {
        const order = PREVIOUS_ORDERS.find(o => o._id === orderId);
        if (!order) return Swal.fire('خطأ', 'الفاتورة غير موجودة في السجل', 'error');
        executeTriplePrinting(order);
    }

