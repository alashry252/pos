    // ==========================================
    // ↩️ تسجيل وإرجاع الفاتورة بالكامل (مرتجع)
    // ==========================================
    async function refundOldOrder(orderId) {
        const order = PREVIOUS_ORDERS.find(o => o._id === orderId);
        if (!order) return Swal.fire('خطأ', 'الفاتورة غير موجودة في السجل', 'error');

        if (order.status === 'refunded') {
            return Swal.fire('تنبيه', 'هذه الفاتورة تم إرجاعها مسبقاً.', 'warning');
        }

        const confirm = await Swal.fire({
            title: 'تأكيد تسجيل مرتجع',
            text: `هل أنت متأكد من رغبتك في إرجاع الفاتورة بالكامل (بون ${order.boneNumber || 'قديم'})؟ سيتم استرداد كميات الأصناف للمخزن وتعديل الحسابات المالية.`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#475569',
            confirmButtonText: 'نعم، قم بالإرجاع',
            cancelButtonText: 'إلغاء'
        });

        if (!confirm.isConfirmed) return;

        try {
            const res = await fetch(`/admin/pos/refund/${orderId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
            const data = await res.json();

            if (data.success) {
                // 1. تحديث حالة الفاتورة محلياً في الذاكرة
                order.status = 'refunded';
                order.refundedAt = data.order.refundedAt;
                order.refundedBy = data.order.refundedBy;
                order.refundedByName = data.order.refundedByName;

                // 2. تحديث الواجهة والبادج في جدول الفواتير السابقة
                const container = document.querySelector(`.refund-action-container-${orderId}`);
                if (container) {
                    container.innerHTML = `<span class="badge bg-danger text-white border-0 px-2 py-1 rounded-pill"><i class="fa-solid fa-rotate-left me-1"></i>مرتجع</span>`;
                }

                // تلوين الصف باللون الأحمر
                const tr = container ? container.closest('tr') : null;
                if (tr) {
                    tr.classList.add('table-danger', 'refunded-row');
                }

                // 3. تحديث كميات كروت المخزون لحظياً أمام الكاشير
                order.items.forEach(item => {
                    const productId = item.productId;
                    const qty = item.quantity || item.qty;
                    const card = document.querySelector(`.pos-card[data-id="${productId}"]`);
                    if (card) {
                        const newStock = parseInt(card.dataset.stock) + qty;
                        card.dataset.stock = newStock;
                        const indicator = card.querySelector('.stock-indicator');
                        if (indicator) {
                            indicator.innerText = `${newStock} ق`;
                            if (newStock <= 5) indicator.classList.add('low');
                            else indicator.classList.remove('low');
                        }
                    }
                });

                Swal.fire({
                    title: 'تم تسجيل المرتجع بنجاح!',
                    text: `تم استرداد كميات الأصناف للمخزن وتعديل السجلات المالية بواسطة: ${data.order.refundedByName}`,
                    icon: 'success',
                    timer: 2500,
                    showConfirmButton: false
                });
            } else {
                throw new Error(data.message);
            }
        } catch (e) {
            Swal.fire('خطأ', e.message || 'فشل الاتصال بالسيرفر لتسجيل المرتجع.', 'error');
        }
    }

    // ==========================================
    // 🚀 معالجة وإرسال عملية البيع بالبيانات المزامنة
    // ==========================================
    async function processOrder() {
        if (cart.length === 0) return Swal.fire('تنبيه', 'السلة فارغة، يرجى إضافة أصناف أولاً', 'warning');
        
        const type = document.querySelector('input[name="orderType"]:checked').value;
        const subTotal = cart.reduce((sum, item) => sum + (item.price * item.qty), 0);
        const discount = parseFloat(document.getElementById('extraDiscount').value) || 0;
        
        let serviceCharge = 0;
        let vat = 0;
        let deliveryFee = 0;
        let customerPaid = 0;
        let customerChange = 0;
        
        if (type === 'dinein') {
            if (document.getElementById('applyService').checked) {
                const servicePct = parseFloat(document.getElementById('servicePercent').value) || 0;
                serviceCharge = subTotal * (servicePct / 100);
            }
            if (document.getElementById('applyVat').checked) {
                const vatPct = parseFloat(document.getElementById('vatPercent').value) || 0;
                vat = subTotal * (vatPct / 100);
            }
        } else if (type === 'delivery') {
            deliveryFee = parseFloat(document.getElementById('deliveryFee').value) || 0;
        } else if (type === 'takeaway') {
            customerPaid = parseFloat(document.getElementById('customerPaid').value) || 0;
        }
        
        const grandTotal = Math.max(0, subTotal + serviceCharge + vat + deliveryFee - discount);
        
        if (type === 'takeaway' && customerPaid > 0 && customerPaid < grandTotal) {
            return Swal.fire('تنبيه', `المبلغ المدفوع (${customerPaid} ج) أقل من إجمالي الفاتورة (${grandTotal} ج)`, 'warning');
        }
        
        if (type === 'takeaway' && customerPaid > 0) {
            customerChange = customerPaid - grandTotal;
        }

        const btn = document.getElementById('payBtn');
        btn.disabled = true;
        btn.innerHTML = '<div class="spinner-border spinner-border-sm"></div> جاري التنفيذ...';

        const orderData = {
            cart,
            paymentMethod: document.getElementById('paymentMethod').value,
            orderType: type,
            discount,
            serviceCharge,
            vat,
            deliveryFee,
            customerPaid,
            customerChange,
            subTotal,
            totalAmount: grandTotal
        };

        try {
            const res = await fetch('/admin/pos/process', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(orderData)
            });
            const data = await res.json();
            
            if (data.success) {
                // 1. استدعاء الطباعة الثلاثية الفورية (بدون مشاكل بسبب التحديث التلقائي)
                executeTriplePrinting(data.order);
                
                // 2. تحديث الفواتير السابقة محلياً في الذاكرة لمنع الحاجة لتحديث الصفحة
                PREVIOUS_ORDERS.unshift(data.order);
                
                // 3. إضافة الصف الجديد لجدول الفواتير السابقة ديناميكياً
                const tbody = document.querySelector('#previousOrdersModal tbody');
                if (tbody) {
                    // مسح رسالة "لا توجد فواتير" إن وجدت
                    const emptyRow = tbody.querySelector('tr td[colspan="6"]');
                    if (emptyRow) {
                        tbody.innerHTML = '';
                    }
                    
                    const typeLabels = { dinein: 'صالة', takeaway: 'تيك أواي', delivery: 'دليفري' };
                    const typeBadgeColors = { dinein: 'primary', takeaway: 'secondary', delivery: 'warning' };
                    const order = data.order;
                    const orderNoShort = (order.orderNumber || '').includes('-') ? order.orderNumber.split('-').pop() : (order.orderNumber || 'N/A');
                    const boneNoText = order.boneNumber || 'قديم';
                    
                    const newRow = document.createElement('tr');
                    newRow.innerHTML = `
                        <td class="ps-4 fw-bold text-primary"><i class="fa-solid fa-hashtag opacity-50 me-1"></i>${order.orderNumber}</td>
                        <td class="fw-black"><span class="badge bg-dark px-2">بون ${boneNoText}</span></td>
                        <td class="small fw-bold">
                            <span class="badge bg-${typeBadgeColors[order.orderType] || 'secondary'} bg-opacity-10 text-${typeBadgeColors[order.orderType] || 'secondary'} border px-2">${typeLabels[order.orderType] || 'تيك أواي'}</span>
                        </td>
                        <td class="small text-muted fw-bold" dir="ltr">${new Date(order.createdAt).toLocaleString('ar-EG')}</td>
                        <td class="fw-black text-success fs-6">${order.totalAmount} ج.م</td>
                        <td class="text-center pe-4">
                            <div class="d-flex justify-content-center gap-2 align-items-center">
                                <button class="btn btn-sm btn-light border rounded-pill shadow-sm" onclick="viewOrderDetails('${order._id}')" title="عرض التفاصيل">
                                    <i class="fa-solid fa-eye text-dark"></i>
                                </button>
                                <button class="btn btn-sm btn-dark rounded-pill shadow-sm" onclick="printOldReceipt('${order._id}')" title="طباعة الفاتورة">
                                    <i class="fa-solid fa-print"></i>
                                </button>
                                <div class="refund-action-container-${order._id}">
                                    <button class="btn btn-sm btn-outline-danger rounded-pill shadow-sm px-2 py-1" onclick="refundOldOrder('${order._id}')" title="تسجيل مرتجع">
                                        <i class="fa-solid fa-rotate-left"></i> مرتجع
                                    </button>
                                </div>
                            </div>
                        </td>
                    `;
                    tbody.insertBefore(newRow, tbody.firstChild);
                }
                
                // 4. تحديث كميات كروت المخزون فورياً دون تحديث الصفحة
                cart.forEach(item => {
                    const card = document.querySelector(`.pos-card[data-id="${item.id}"]`);
                    if (card) {
                        const newStock = Math.max(0, parseInt(card.dataset.stock) - item.qty);
                        card.dataset.stock = newStock;
                        const indicator = card.querySelector('.stock-indicator');
                        if (indicator) {
                            indicator.innerText = `${newStock} ق`;
                            if (newStock <= 5) indicator.classList.add('low');
                            else indicator.classList.remove('low');
                        }
                    }
                });
                
                // 5. تصفير السلة والمدخلات
                cart = [];
                document.getElementById('extraDiscount').value = 0;
                document.getElementById('customerPaid').value = 0;
                renderCart();

                Swal.fire({
                    title: 'تم حفظ الفاتورة بنجاح!',
                    text: 'تم إرسال الفواتير الثلاثية للطباعة تلقائياً (بون المطبخ + بون العميل + نسخة الإدارة).',
                    icon: 'success',
                    timer: 2500,
                    showConfirmButton: false
                });
                
                // إعادة تفعيل زر الدفع فوراً للعملية القادمة
                btn.disabled = false;
                btn.innerHTML = 'دفع وتأكيد الفاتورة <i class="fa-solid fa-check-circle ms-1"></i>';
            } else {
                throw new Error(data.message);
            }
        } catch (e) {
            Swal.fire('خطأ', e.message, 'error');
            btn.disabled = false;
            btn.innerHTML = 'دفع وتأكيد الفاتورة <i class="fa-solid fa-check-circle ms-1"></i>';
        }
    }
</script>

