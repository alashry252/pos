<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<link rel="stylesheet" href="/css/pos.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

<div class="main-content-wrapper">
    <main class="container-fluid px-2 px-lg-3 py-3">
        
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="fw-black text-dark mb-0"><i class="fa-solid fa-desktop text-primary me-2"></i>نقطة البيع (POS)</h4>
            <button class="btn btn-dark rounded-pill fw-bold px-4 shadow-sm" data-bs-toggle="modal" data-bs-target="#previousOrdersModal">
                <i class="fa-solid fa-clock-rotate-left me-2"></i> الفواتير السابقة
            </button>
        </div>

        <div class="pos-wrapper fade-in-up">
            
            <!-- قسم المنتجات والبحث -->
            <div class="products-section shadow-sm border rounded-4 bg-white d-flex flex-column overflow-hidden flex-grow-1">
                <div class="p-3 border-bottom bg-white">
                    <!-- 1. شريط البحث (عرض كامل) -->
                    <div class="mb-3">
                        <div class="input-group shadow-none rounded-pill overflow-hidden bg-light border p-1">
                            <span class="input-group-text bg-transparent border-0"><i class="fa-solid fa-magnifying-glass text-muted fs-5"></i></span>
                            <input type="text" id="posSearch" class="form-control border-0 bg-transparent shadow-none fw-bold" placeholder="بحث سريع عن صنف باسمه أو كود الـ SKU..." autocomplete="off">
                        </div>
                    </div>
                    <!-- 2. قائمة الأقسام (عرض كامل مع تمرير أفقي ممتاز) -->
                    <div class="d-flex gap-2 overflow-x-auto pb-1" id="categoryList">
                        <button class="btn btn-sm btn-primary rounded-pill fw-bold px-4 py-2 category-pill active" onclick="filterCategory('الكل', this)">الكل</button>
                        <% 
                            const categories = [...new Set(products.map(p => p.category))];
                            categories.forEach(cat => { 
                        %>
                            <button class="btn btn-sm btn-light rounded-pill fw-bold px-4 py-2 text-muted border category-pill" onclick="filterCategory('<%= cat %>', this)"><%= cat %></button>
                        <% }) %>
                    </div>
                </div>

                <div class="products-scroll-area" style="background: #fbfcfd;">
                    <div class="products-grid" id="productsGrid">
                        <% products.forEach(p => { %>
                            <div class="pos-card" 
                                 data-id="<%= p._id %>" 
                                 data-name="<%= p.name %>" 
                                 data-price="<%= p.price %>" 
                                 data-stock="<%= p.quantity %>"
                                 data-category="<%= p.category %>"
                                 data-sku="<%= p.sku %>"
                                 onclick="handleAddToCart(this)">
                                
                                <div class="d-flex justify-content-between align-items-start">
                                    <span class="card-price"><%= p.price %><small class="fs-6 fw-bold">ج</small></span>
                                    <span class="stock-indicator <%= p.quantity <= 5 ? 'low' : '' %>"><%= p.quantity %> ق</span>
                                </div>
                                <div class="card-title"><%= p.name %></div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>

            <!-- سلة المبيعات (Sidebar) -->
            <div class="cart-section border rounded-4 bg-white d-flex flex-column overflow-hidden" style="width: 420px; min-width: 420px;">
                <div class="p-3 border-bottom d-flex justify-content-between align-items-center bg-white flex-shrink-0">
                    <h6 class="fw-black mb-0 text-dark">الفاتورة الحالية</h6>
                    <button class="btn btn-sm btn-outline-danger rounded-pill fw-bold border-0" onclick="confirmClearCart()">
                        <i class="fa-solid fa-trash-can"></i> إفراغ
                    </button>
                </div>

                <!-- جسم السلة القابل للتمرير بالكامل (يمنع مشكلة شاشات التابلت والشاشات الصغيرة) -->
                <div class="cart-scrollable-body d-flex flex-column flex-grow-1 overflow-y-auto" style="min-height: 0;">
                    
                    <!-- قائمة الأصناف في السلة القابلة للتمرير الداخلي (مرنة جداً) -->
                    <div class="cart-scroll-area flex-shrink-0" style="min-height: 180px;">
                        <div id="cartItemsContainer"></div>
                        
                        <div id="emptyCartMsg" class="text-center py-5">
                            <i class="fa-solid fa-receipt fs-1 text-muted opacity-25 mb-2"></i>
                            <p class="text-muted fw-bold small">لا توجد منتجات مضافة</p>
                        </div>
                    </div>

                    <!-- إعدادات الدفع ونوع الطلب والحسابات التفصيلية -->
                    <div class="p-3 bg-white border-top flex-shrink-0">
                        <!-- خيارات طريقة الدفع ونوع الطلب -->
                        <div class="mb-3">
                            <label class="small text-muted fw-bold mb-2 d-block"><i class="fa-solid fa-utensils me-1"></i> نوع الطلب</label>
                            <div class="btn-group w-100 mb-2" role="group">
                                <input type="radio" class="btn-check" name="orderType" id="typeTakeaway" value="takeaway" checked onchange="changeOrderType()">
                                <label class="btn order-type-btn active" for="typeTakeaway" id="lblTakeaway">تيك أواي</label>

                                <input type="radio" class="btn-check" name="orderType" id="typeDinein" value="dinein" onchange="changeOrderType()">
                                <label class="btn order-type-btn" for="typeDinein" id="lblDinein">صالة</label>

                                <input type="radio" class="btn-check" name="orderType" id="typeDelivery" value="delivery" onchange="changeOrderType()">
                                <label class="btn order-type-btn" for="typeDelivery" id="lblDelivery">دليفري</label>
                            </div>
                        </div>

                        <div class="row g-2 mb-3 bg-light p-2 rounded-3 border">
                            <div class="col-6">
                                <label class="small text-muted fw-bold mb-1">طريقة الدفع</label>
                                <select class="form-select form-select-sm border shadow-none fw-bold" id="paymentMethod">
                                    <option value="cash">نقدي (كاش)</option>
                                    <option value="card">بطاقة بنكية</option>
                                </select>
                            </div>
                            <div class="col-6">
                                <label class="small text-muted fw-bold mb-1">الخصم (ج.م)</label>
                                <input type="number" id="extraDiscount" class="form-control form-control-sm border fw-bold text-danger" value="0" min="0" oninput="calculateTotals()">
                            </div>
                        </div>

                        <!-- حقول ديناميكية حسب نوع الطلب -->
                        <!-- 1. حقول الصالة (اختياري) -->
                        <div id="dineinFields" class="d-none bg-light p-2 rounded-3 border mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="applyService" checked onchange="calculateTotals()">
                                    <label class="form-check-label small fw-bold text-dark" for="applyService">إضافة خدمة صالة</label>
                                </div>
                                <div class="d-flex align-items-center gap-1">
                                    <input type="number" id="servicePercent" class="form-control form-control-sm text-center fw-bold custom-input" value="12" style="width: 50px;" oninput="calculateTotals()">
                                    <span class="small fw-bold">%</span>
                                </div>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="applyVat" checked onchange="calculateTotals()">
                                    <label class="form-check-label small fw-bold text-dark" for="applyVat">إضافة ضريبة (VAT)</label>
                                </div>
                                <div class="d-flex align-items-center gap-1">
                                    <input type="number" id="vatPercent" class="form-control form-control-sm text-center fw-bold custom-input" value="14" style="width: 50px;" oninput="calculateTotals()">
                                    <span class="small fw-bold">%</span>
                                </div>
                            </div>
                        </div>

                        <!-- 2. حقول الدليفري -->
                        <div id="deliveryFields" class="d-none bg-light p-2 rounded-3 border mb-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="small fw-bold text-dark"><i class="fa-solid fa-truck me-1"></i> خدمة التوصيل</span>
                                <div class="d-flex align-items-center gap-1">
                                    <input type="number" id="deliveryFee" class="form-control form-control-sm text-center fw-bold custom-input" value="15" style="width: 70px;" oninput="calculateTotals()">
                                    <span class="small fw-bold">ج</span>
                                </div>
                            </div>
                        </div>

                        <!-- 3. حاسبة الزبون للتيك أواي -->
                        <div id="takeawayFields" class="bg-light p-2 rounded-3 border mb-3">
                            <div class="row g-2 align-items-center">
                                <div class="col-6">
                                    <label class="small text-muted fw-bold mb-1 d-block">المدفوع من الزبون</label>
                                    <input type="number" id="customerPaid" class="form-control form-control-sm border fw-bold text-success" value="0" min="0" oninput="calculateTotals()">
                                </div>
                                <div class="col-6 text-center">
                                    <div class="calc-card p-2 text-center">
                                        <span class="calc-title d-block mb-1">المتبقي (الباقي)</span>
                                        <span id="customerChangeDisplay" class="calc-value change">0 ج</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- تفصيل الحسابات المعروضة -->
                        <div class="px-1 small mb-2">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-muted fw-bold">الإجمالي الفرعي:</span>
                                <span id="subTotalDisplay" class="fw-bold text-dark">0 ج</span>
                            </div>
                            <div id="serviceRow" class="d-none justify-content-between mb-1 text-primary">
                                <span class="fw-bold">خدمة صالة:</span>
                                <span id="serviceDisplay" class="fw-bold">0 ج</span>
                            </div>
                            <div id="vatRow" class="d-none justify-content-between mb-1 text-info">
                                <span class="fw-bold">ضريبة القيمة المضافة:</span>
                                <span id="vatDisplay" class="fw-bold">0 ج</span>
                            </div>
                            <div id="deliveryRow" class="d-none justify-content-between mb-1 text-warning">
                                <span class="fw-bold">خدمة التوصيل:</span>
                                <span id="deliveryDisplay" class="fw-bold">0 ج</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 3. أسفل السلة الثابت والجاهز للدفع دائماً -->
                <div class="p-3 bg-white border-top shadow-sm flex-shrink-0">
                    <div class="d-flex justify-content-between align-items-center p-3 totals-box text-white">
                        <span class="fw-bold fs-5">المطلوب دفعه</span>
                        <span id="grandTotalDisplay" class="total-number fs-3 text-warning">0 ج</span>
                    </div>
                    
                    <button class="btn pay-btn w-100 py-3 rounded-3 mt-3" id="payBtn" onclick="processOrder()">
                        دفع وتأكيد الفاتورة <i class="fa-solid fa-check-circle ms-1"></i>
                    </button>
                </div>
            </div>
        </div>
    </main>
</div>

<!-- موديل الفواتير السابقة -->
<div class="modal fade" id="previousOrdersModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-header border-bottom bg-light p-4">
                <h5 class="modal-title fw-black"><i class="fa-solid fa-file-invoice me-2 text-primary"></i>سجل الفواتير الأخيرة</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 custom-table">
                        <thead class="bg-light text-muted small">
                            <tr>
                                <th class="ps-4 py-3">رقم الفاتورة</th>
                                <th>البون</th>
                                <th>نوع الطلب</th>
                                <th>التاريخ والوقت</th>
                                <th>الإجمالي</th>
                                <th class="text-center pe-4">إجراءات</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (typeof orders !== 'undefined' && orders.length > 0) { %>
                                <% orders.forEach(order => { %>
                                    <tr class="<%= order.status === 'refunded' ? 'table-danger refunded-row' : '' %>">
                                        <td class="ps-4 fw-bold text-primary"><i class="fa-solid fa-hashtag opacity-50 me-1"></i><%= order.orderNumber %></td>
                                        <td class="fw-black"><span class="badge bg-dark px-2">بون <%= order.boneNumber || 'قديم' %></span></td>
                                        <td class="small fw-bold">
                                            <% if (order.orderType === 'dinein') { %>
                                                <span class="badge bg-primary bg-opacity-10 text-primary border px-2">صالة</span>
                                            <% } else if (order.orderType === 'delivery') { %>
                                                <span class="badge bg-warning bg-opacity-10 text-warning border px-2">دليفري</span>
                                            <% } else { %>
                                                <span class="badge bg-secondary bg-opacity-10 text-secondary border px-2">تيك أواي</span>
                                            <% } %>
                                        </td>
                                        <td class="small text-muted fw-bold" dir="ltr"><%= new Date(order.createdAt).toLocaleString('ar-EG') %></td>
                                        <td class="fw-black text-success fs-6"><%= order.totalAmount %> ج.م</td>
                                        <td class="text-center pe-4">
                                            <div class="d-flex justify-content-center gap-2 align-items-center">
                                                <button class="btn btn-sm btn-light border rounded-pill shadow-sm" onclick="viewOrderDetails('<%= order._id %>')" title="عرض التفاصيل">
                                                    <i class="fa-solid fa-eye text-dark"></i>
                                                </button>
                                                <button class="btn btn-sm btn-dark rounded-pill shadow-sm" onclick="printOldReceipt('<%= order._id %>')" title="طباعة الفاتورة">
                                                    <i class="fa-solid fa-print"></i>
                                                </button>
                                                <div class="refund-action-container-<%= order._id %>">
                                                    <% if (order.status === 'refunded') { %>
                                                        <span class="badge bg-danger text-white border-0 px-2 py-1 rounded-pill"><i class="fa-solid fa-rotate-left me-1"></i>مرتجع</span>
                                                    <% } else { %>
                                                        <button class="btn btn-sm btn-outline-danger rounded-pill shadow-sm px-2 py-1" onclick="refundOldOrder('<%= order._id %>')" title="تسجيل مرتجع">
                                                            <i class="fa-solid fa-rotate-left"></i> مرتجع
                                                        </button>
                                                    <% } %>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="6" class="text-center py-5 text-muted">
                                        <i class="fa-solid fa-receipt fs-1 mb-3 opacity-25"></i>
                                        <h6>لا توجد أي فواتير مسجلة في النظام حتى الآن.</h6>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- حاوية مخفية تُستخدم في تجهيز وطباعة الفواتير -->
<div id="printFrameContainer" style="display: none;"></div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    // حقن الفواتير السابقة في الجافاسكريبت لسرعة المعالجة والبحث
    const PREVIOUS_ORDERS = <%- JSON.stringify(locals.orders || []).replace(/</g, '\\u003c') %>;
    
    let cart = [];

    // ==========================================
    // 🧠 محرك نوع الطلب والحسابات التلقائية
    // ==========================================
    function changeOrderType() {
        const type = document.querySelector('input[name="orderType"]:checked').value;
        
        // إزالة الفئات النشطة من جميع التسميات
        document.getElementById('lblTakeaway').classList.remove('active');
        document.getElementById('lblDinein').classList.remove('active');
        document.getElementById('lblDelivery').classList.remove('active');
        
        // تفعيل الزر النشط وتعديل ظهور الحقول
        if (type === 'takeaway') {
            document.getElementById('lblTakeaway').classList.add('active');
            document.getElementById('takeawayFields').classList.remove('d-none');
            document.getElementById('dineinFields').classList.add('d-none');
            document.getElementById('deliveryFields').classList.add('d-none');
        } else if (type === 'dinein') {
            document.getElementById('lblDinein').classList.add('active');
            document.getElementById('takeawayFields').classList.add('d-none');
            document.getElementById('dineinFields').classList.remove('d-none');
            document.getElementById('deliveryFields').classList.add('d-none');
        } else if (type === 'delivery') {
            document.getElementById('lblDelivery').classList.add('active');
            document.getElementById('takeawayFields').classList.add('d-none');
            document.getElementById('dineinFields').classList.add('d-none');
            document.getElementById('deliveryFields').classList.remove('d-none');
        }
        
        calculateTotals();
    }

    function handleAddToCart(element) {
        const product = { id: element.dataset.id, name: element.dataset.name, price: parseFloat(element.dataset.price), stock: parseInt(element.dataset.stock) };
        const existing = cart.find(i => i.id === product.id);
        
        if (existing) {
            if (existing.qty >= product.stock) {
                return Swal.fire({ icon: 'warning', title: 'تنبيه', text: 'الكمية المطلوبة تتجاوز المتاح في المخزن', timer: 1200, showConfirmButton: false });
            }
            existing.qty++;
        } else {
            cart.push({ ...product, qty: 1 });
        }
        renderCart();
    }

    function updateQty(id, delta) {
        const item = cart.find(i => i.id === id);
        if (!item) return;
        if (delta > 0 && item.qty >= item.stock) {
            return Swal.fire({ icon: 'warning', title: 'تنبيه', text: 'الكمية المطلوبة تتجاوز المتاح في المخزن', timer: 1200, showConfirmButton: false });
        }
        item.qty += delta;
        if (item.qty <= 0) cart = cart.filter(i => i.id !== id);
        renderCart();
    }

    function removeFromCart(id) {
        cart = cart.filter(i => i.id !== id);
        renderCart();
    }

    function renderCart() {
        const container = document.getElementById('cartItemsContainer');
        const emptyMsg = document.getElementById('emptyCartMsg');
        
        if (cart.length === 0) {
            container.innerHTML = '';
            emptyMsg.classList.remove('d-none');
            calculateTotals();
            return;
        }

        emptyMsg.classList.add('d-none');
        container.innerHTML = cart.map(item => `
            <div class="cart-item-row d-flex justify-content-between align-items-center shadow-sm">
                <div style="flex: 1; padding-left: 10px; text-align: right;">
                    <div class="fw-black text-dark" style="font-size: 0.95rem; line-height: 1.3;">${item.name}</div>
                    <div class="text-muted fw-bold" style="font-size: 0.82rem; margin-top: 2px;">${item.price} ج × ${item.qty}</div>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <div class="fw-black text-primary me-3" style="font-size: 1.05rem;">${(item.price * item.qty).toFixed(0)} ج</div>
                    <div class="qty-control d-flex align-items-center gap-1">
                        <button class="qty-btn" onclick="updateQty('${item.id}', -1)"><i class="fa-solid fa-minus" style="font-size: 0.7rem;"></i></button>
                        <span class="fw-bold px-1" style="min-width: 20px; text-align: center; font-size: 0.9rem; color: #1e293b;">${item.qty}</span>
                        <button class="qty-btn" onclick="updateQty('${item.id}', 1)"><i class="fa-solid fa-plus" style="font-size: 0.7rem;"></i></button>
                    </div>
                    <button class="btn btn-sm btn-link text-danger p-1 border-0 ms-2 remove-item-btn" onclick="removeFromCart('${item.id}')" title="حذف بالكامل">
                        <i class="fa-solid fa-trash-can" style="font-size: 0.95rem;"></i>
                    </button>
                </div>
            </div>
        `).join('');

        calculateTotals();
    }

    function calculateTotals() {
        const subTotal = cart.reduce((sum, item) => sum + (item.price * item.qty), 0);
        const discount = parseFloat(document.getElementById('extraDiscount').value) || 0;
        
        const type = document.querySelector('input[name="orderType"]:checked').value;
        
        let serviceVal = 0;
        let vatVal = 0;
        let deliveryVal = 0;
        
        // إعادة تهيئة الحسابات الظاهرة
        document.getElementById('serviceRow').classList.replace('d-flex', 'd-none');
        document.getElementById('vatRow').classList.replace('d-flex', 'd-none');
        document.getElementById('deliveryRow').classList.replace('d-flex', 'd-none');
        
        if (type === 'dinein') {
            const isServiceToggled = document.getElementById('applyService').checked;
            const isVatToggled = document.getElementById('applyVat').checked;
            
            if (isServiceToggled) {
                const servicePct = parseFloat(document.getElementById('servicePercent').value) || 0;
                serviceVal = subTotal * (servicePct / 100);
                document.getElementById('serviceRow').classList.replace('d-none', 'd-flex');
                document.getElementById('serviceDisplay').innerText = serviceVal.toFixed(0) + ' ج';
            }
            if (isVatToggled) {
                const vatPct = parseFloat(document.getElementById('vatPercent').value) || 0;
                vatVal = subTotal * (vatPct / 100);
                document.getElementById('vatRow').classList.replace('d-none', 'd-flex');
                document.getElementById('vatDisplay').innerText = vatVal.toFixed(0) + ' ج';
            }
        } else if (type === 'delivery') {
            deliveryVal = parseFloat(document.getElementById('deliveryFee').value) || 0;
            document.getElementById('deliveryRow').classList.replace('d-none', 'd-flex');
            document.getElementById('deliveryDisplay').innerText = deliveryVal.toFixed(0) + ' ج';
        }
        
        const grandTotal = Math.max(0, subTotal + serviceVal + vatVal + deliveryVal - discount);
        
        document.getElementById('subTotalDisplay').innerText = subTotal.toFixed(0) + ' ج';
        document.getElementById('grandTotalDisplay').innerText = grandTotal.toFixed(0) + ' ج';
        
        // حساب الباقي في التيك أواي
        if (type === 'takeaway') {
            const paid = parseFloat(document.getElementById('customerPaid').value) || 0;
            const change = Math.max(0, paid - grandTotal);
            document.getElementById('customerChangeDisplay').innerText = change.toFixed(0) + ' ج';
        }
    }

    // فلترة وبحث المنتجات
    const searchInput = document.getElementById('posSearch');
    let currentCategory = 'الكل';
    if(searchInput) { searchInput.addEventListener('input', applyFilters); }

    function filterCategory(cat, btn) {
        currentCategory = cat;
        document.querySelectorAll('.category-pill').forEach(p => {
            p.classList.remove('btn-primary', 'active'); p.classList.add('btn-light', 'text-muted');
        });
        btn.classList.remove('btn-light', 'text-muted'); btn.classList.add('btn-primary', 'active');
        applyFilters();
    }

    function applyFilters() {
        const term = searchInput.value.toLowerCase();
        document.querySelectorAll('.pos-card').forEach(card => {
            const matchSearch = card.dataset.name.toLowerCase().includes(term) || card.dataset.sku.toLowerCase().includes(term);
