    // دالة توليد الكود القديم لثلاث فواتير معاً متتالية (الـ fallback)
    function generateTripleReceiptsHTML(order) {
        const { ticketKitchen, ticketCustomer, ticketManagement } = getReceiptTemplates(order);
        return `
            <html>
            <head>
                <title>Print Order Receipts</title>
                ${generateReceiptCSS()}
            </head>
            <body>
                ${ticketKitchen}
                <div class="page-break"></div>
