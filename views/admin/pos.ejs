                    ${order.vat > 0 ? `<div>الضريبة 14%: ${order.vat.toFixed(0)} ج</div>` : ''}
                    ${order.deliveryFee > 0 ? `<div>توصيل: ${order.deliveryFee} ج</div>` : ''}
                    ${order.discount > 0 ? `<div class="text-danger">خصم: ${order.discount} ج</div>` : ''}
                </div>
                <h4 class="text-danger fw-black mt-3">الإجمالي النهائي: ${(order.totalAmount || 0)} ج.م</h4>
            `,
            width: '500px',
            showCloseButton: true,
            showConfirmButton: true,
            confirmButtonText: '<i class="fa-solid fa-print"></i> طباعة الفاتورة الثلاثية',
