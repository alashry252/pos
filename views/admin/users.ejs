<%- include('../partials/header') %>
<%- include('../partials/navbar') %> 

<link rel="stylesheet" href="/css/users.css">

<div class="main-content-wrapper">
    <main class="container-fluid px-3 px-lg-5 py-4 fade-in-up">
        
        <% if (typeof error !== 'undefined' && error) { %>
            <script>
                document.addEventListener('DOMContentLoaded', function() {
                    Swal.fire({
                        title: 'تنبيه',
                        text: '<%= error %>',
                        icon: 'error',
                        confirmButtonColor: '#ef4444',
                        confirmButtonText: 'إغلاق',
                        customClass: { confirmButton: 'rounded-pill px-4 fw-bold' }
                    });
                });
            </script>
        <% } %>

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 pb-3 border-bottom">
            <div class="mb-3 mb-md-0">
                <h3 class="fw-black text-dark mb-1 d-flex align-items-center gap-2">
                    <div class="bg-primary bg-opacity-10 text-primary p-2 rounded-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                        <i class="fa-solid fa-users-gear fs-5"></i>
                    </div>
                    إدارة الصلاحيات
                </h3>
                <p class="text-muted small mb-0 ms-5" style="margin-right: 3.2rem;">التحكم في حسابات الموظفين وسجل النشاطات</p>
            </div>
            <button class="btn btn-primary-gradient fw-bold px-4 py-2 rounded-pill shadow-sm d-flex align-items-center gap-2 transition-all hover-lift" data-bs-toggle="modal" data-bs-target="#userModal" onclick="resetUserForm()">
                <i class="fa-solid fa-plus"></i> إضافة مستخدم جديد
            </button>
        </div>

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0 custom-table">
                                <thead class="bg-light">
                                    <tr class="text-muted text-uppercase tracking-wide">
                                        <th class="py-3 ps-4 border-0">المستخدم</th>
                                        <th class="py-3 border-0">الدور</th>
                                        <th class="py-3 border-0">تاريخ الانضمام</th>
                                        <th class="py-3 text-center pe-4 border-0">الإجراءات</th>
                                    </tr>
                                </thead>
                                <tbody class="border-top-0">
                                    <% if (users.length === 0) { %>
                                        <tr>
                                            <td colspan="4" class="text-center py-5">
                                                <div class="text-muted mb-3"><i class="fa-solid fa-folder-open fs-1 opacity-25"></i></div>
                                                <h6 class="fw-bold">لا يوجد مستخدمين مسجلين</h6>
                                                <p class="small text-muted">اضغط على "إضافة مستخدم جديد" للبدء.</p>
                                            </td>
                                        </tr>
                                    <% } else { %>
                                        <% users.forEach(u => { %>
                                            <tr>
                                                <td class="ps-4 py-3">
                                                    <div class="d-flex align-items-center gap-3">
                                                        <div class="avatar-circle text-primary fw-black fs-5 shadow-sm">
                                                            <%= u.name.charAt(0).toUpperCase() %>
                                                        </div>
                                                        <div>
                                                            <div class="fw-bold text-dark d-flex align-items-center gap-2">
                                                                <%= u.name %>
                                                                <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25" style="font-family: monospace; font-size: 0.75rem;" title="الرقم التعريفي للموظف">
                                                                    <i class="fa-solid fa-hashtag me-1 opacity-50"></i><%= u.accountId %>
                                                                </span>
                                                            </div>
                                                            <div class="text-muted small font-monospace"><i class="fa-solid fa-at opacity-50 me-1"></i><%= u.username %></div>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td class="py-3">
                                                    <% if (u.role === 'admin') { %>
                                                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 px-3 py-2 rounded-pill fw-bold">مدير نظام</span>
                                                    <% } else { %>
                                                        <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 px-3 py-2 rounded-pill fw-bold">موظف دعم</span>
                                                    <% } %>
                                                </td>
                                                <td class="text-muted small py-3 fw-medium">
                                                    <i class="fa-regular fa-calendar me-1 opacity-50"></i> <%= u.createdAt.toLocaleDateString('ar-EG') %>
                                                </td>
                                                <td class="text-center pe-4 py-3">
                                                    <div class="d-flex justify-content-center gap-2">
                                                        <button class="btn-action btn-edit shadow-sm" onclick="editUser('<%= u._id %>', '<%= u.name %>', '<%= u.username %>', '<%= u.role %>')" title="تعديل">
                                                            <i class="fa-solid fa-pen"></i>
                                                        </button>
                                                        <% if (u._id.toString() !== user.id) { %>
                                                            <button class="btn-action btn-delete shadow-sm" onclick="confirmDelete('<%= u._id %>')" title="حذف">
                                                                <i class="fa-solid fa-trash"></i>
                                                            </button>
                                                        <% } else { %>
                                                            <button class="btn-action text-muted" style="cursor: not-allowed; opacity: 0.5;" disabled title="لا يمكنك حذف حسابك الحالي">
                                                                <i class="fa-solid fa-lock"></i>
                                                            </button>
                                                        <% } %>
                                                    </div>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 h-100 bg-white">
                    <div class="card-header bg-transparent border-0 pt-4 px-4 pb-0">
                        <h6 class="fw-black text-dark mb-0 d-flex align-items-center gap-2">
                            <i class="fa-solid fa-clock-rotate-left text-primary fs-5"></i> سجل النشاطات
                        </h6>
                    </div>
                    <div class="card-body p-4">
                        <div class="timeline-wrapper">
                            <% recentActivities.forEach(activity => { %>
                                <div class="timeline-item">
                                    <div class="timeline-marker bg-primary"></div>
                                    <div class="timeline-content shadow-sm">
                                        <div class="fw-bold text-dark fs-6"><%= activity.action %></div>
                                        <div class="text-muted small mt-1 d-flex justify-content-between align-items-center">
                                            <span><i class="fa-regular fa-user me-1"></i><%= activity.user %></span>
                                            <span class="opacity-75 badge bg-light text-dark"><%= activity.time %></span>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<div class="modal fade" id="userModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg overflow-hidden">
            <div class="bg-primary bg-gradient" style="height: 5px;"></div>
            
            <div class="modal-header border-bottom-0 p-4 pb-2">
                <h5 class="modal-title fw-black d-flex align-items-center gap-2" id="modalTitle">
                    <div class="bg-primary bg-opacity-10 text-primary p-2 rounded-3 d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">
                        <i class="fa-solid fa-user-plus fs-6"></i>
                    </div>
                    <span id="modalTitleText">إضافة مستخدم</span>
                </h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="إغلاق"></button>
            </div>
            
            <div class="modal-body p-4 pt-0">
                <form id="userForm" action="/admin/users/create" method="POST" novalidate>
                    
                    <div class="row g-3">
                        <div class="col-md-6 form-floating mb-2">
                            <input type="text" class="form-control rounded-3 bg-light border-0 shadow-none" name="name" id="userNameInput" placeholder="الاسم بالكامل" required autocomplete="off">
                            <label for="userNameInput" class="text-muted ms-2">الاسم بالكامل</label>
                            <div class="invalid-feedback small fw-bold px-2">مطلوب*</div>
                        </div>
                        
                        <div class="col-md-6 form-floating mb-2">
                            <input type="text" class="form-control rounded-3 bg-light border-0 shadow-none text-start" dir="ltr" name="username" id="userUsernameInput" placeholder="اسم المستخدم" required autocomplete="off" pattern="^[a-zA-Z0-9_]{4,30}$">
                            <label for="userUsernameInput" class="text-muted ms-2">اسم المستخدم (للدخول)</label>
                            <div class="invalid-feedback small fw-bold px-2">إنجليزي وأرقام فقط (4 حروف ع الأقل)</div>
                        </div>
                    </div>
                    
                    <div id="passwordSection">
                        <div class="form-floating mb-2 position-relative">
                            <input type="password" class="form-control rounded-3 bg-light border-0 shadow-none text-start pe-5" dir="ltr" name="password" id="userPasswordInput" placeholder="كلمة المرور" required minlength="8">
                            <label for="userPasswordInput" class="text-muted">كلمة المرور</label>
                            <i class="fa-regular fa-eye password-toggle" id="togglePass"></i>
                            
                            <div class="progress mt-2 bg-light border" style="height: 5px; border-radius: 3px;">
                                <div id="strengthMeter" class="progress-bar bg-danger transition-all" role="progressbar" style="width: 0%;"></div>
                            </div>
                            <small id="strengthText" class="text-muted d-block mt-1 ps-1" style="font-size: 0.75rem;">8 أحرف على الأقل</small>
                        </div>

                        <div class="form-floating mb-3 position-relative">
                            <input type="password" class="form-control rounded-3 bg-light border-0 shadow-none text-start pe-5" dir="ltr" id="confirmPasswordInput" placeholder="تأكيد كلمة المرور" required>
                            <label for="confirmPasswordInput" class="text-muted">تأكيد كلمة المرور</label>
                            <i class="fa-regular fa-eye password-toggle" id="toggleConfirmPass"></i>
                            
                            <small id="passwordMatchError" class="text-danger d-none mt-1 d-block fw-bold ps-1" style="font-size: 0.8rem;">
                                <i class="fa-solid fa-triangle-exclamation me-1"></i> كلمتا المرور غير متطابقتين!
                            </small>
                        </div>
                    </div>

                    <div id="passwordHelp" class="alert alert-warning border-warning border-opacity-25 bg-warning bg-opacity-10 d-none p-3 rounded-3 mb-3 d-flex gap-2 align-items-start">
                        <i class="fa-solid fa-shield-halved text-warning mt-1 fs-5"></i>
                        <small class="fw-bold text-warning-emphasis lh-sm">
                            إجراء أمني: لا يمكن تعديل كلمة المرور أو اسم المستخدم من هذه الشاشة لمنع اختراق الحسابات.
                        </small>
                    </div>
                    
                    <div class="form-floating mb-4">
                        <select class="form-select rounded-3 bg-light border-0 shadow-none fw-bold" name="role" id="userRoleInput" required>
                            <option value="" disabled selected>-- اختر الصلاحية --</option>
                            <option value="agent">موظف دعم عام (Agent)</option>
                            <option value="admin">مدير نظام كامل (Admin)</option>
                        </select>
                        <label for="userRoleInput" class="text-muted">تحديد الصلاحية</label>
                        <div class="invalid-feedback small fw-bold px-2">يجب اختيار الصلاحية*</div>
                    </div>
                    
                    <button type="submit" class="btn btn-primary-gradient w-100 py-3 fw-bold rounded-pill shadow-sm transition-all hover-lift" id="submitBtn">
                        <span class="btn-text">حفظ بيانات المستخدم <i class="fa-solid fa-check ms-1"></i></span>
                        <div class="spinner-border spinner-border-sm text-light btn-loader" role="status"></div>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // ==========================================
        // 1. تهيئة المتغيرات وعناصر الـ DOM
        // ==========================================
        const userForm = document.getElementById('userForm');
        const modalEl = document.getElementById('userModal');
        const userModal = new bootstrap.Modal(modalEl);
        const modalTitleText = document.getElementById('modalTitleText');
        const submitBtn = document.getElementById('submitBtn');
        const nameInput = document.getElementById('userNameInput');
        const usernameInput = document.getElementById('userUsernameInput');
        const passwordInput = document.getElementById('userPasswordInput');
        const confirmPasswordInput = document.getElementById('confirmPasswordInput');
        const roleInput = document.getElementById('userRoleInput');
        const passwordSection = document.getElementById('passwordSection');
        const passwordHelp = document.getElementById('passwordHelp');
        const modalIcon = document.querySelector('#modalTitle i');
        const matchError = document.getElementById('passwordMatchError');
        const strengthMeter = document.getElementById('strengthMeter');
        const strengthText = document.getElementById('strengthText');
        
        let isEditMode = false;

        // ==========================================
        // 2. تجربة المستخدم: التركيز التلقائي عند فتح النافذة
        // ==========================================
        modalEl.addEventListener('shown.bs.modal', function () {
            if (!isEditMode) {
                nameInput.focus();
            } else {
                roleInput.focus(); // في وضع التعديل، التركيز يكون على الصلاحية لأن الباقي مقفول
            }
        });

        // تنظيف الواجهة تماماً عند إغلاق النافذة
        modalEl.addEventListener('hidden.bs.modal', function () {
            resetUserForm();
        });

        // ==========================================
        // 3. إظهار/إخفاء الباسورد (تفاعل العين)
        // ==========================================
        function setupPasswordToggle(toggleIconId, inputElement) {
            const icon = document.getElementById(toggleIconId);
            if(icon && inputElement) {
                icon.addEventListener('click', function() {
                    const isPassword = inputElement.type === 'password';
                    inputElement.type = isPassword ? 'text' : 'password';
                    this.classList.toggle('fa-eye');
                    this.classList.toggle('fa-eye-slash');
                    this.style.color = isPassword ? '#6366f1' : '#94a3b8';
                });
            }
        }
        setupPasswordToggle('togglePass', passwordInput);
        setupPasswordToggle('toggleConfirmPass', confirmPasswordInput);

        // ==========================================
        // 4. مقياس قوة الباسورد الحي (Live Strength)
        // ==========================================
        passwordInput.addEventListener('input', function() {
            const val = this.value;
            let strength = 0;
            
            if (val.length >= 8) strength += 25; 
            if (val.match(/[a-z]+/)) strength += 25; 
            if (val.match(/[A-Z]+/)) strength += 25; 
            if (val.match(/[0-9]+/)) strength += 25; 
            if (val.match(/[$@#&!]+/)) strength += 25; 

            strength = Math.min(strength, 100);
            strengthMeter.style.width = strength + '%';

            if (val.length === 0) {
                strengthMeter.style.width = '0%';
                strengthText.innerText = '8 أحرف على الأقل';
                strengthText.className = 'text-muted d-block mt-1 ps-1';
            } else if (strength < 50 || val.length < 8) {
                strengthMeter.className = 'progress-bar bg-danger transition-all';
                strengthText.innerText = 'ضعيفة جداً (استخدم حروف وأرقام)';
                strengthText.className = 'text-danger d-block mt-1 ps-1 fw-bold';
            } else if (strength < 75) {
                strengthMeter.className = 'progress-bar bg-warning transition-all';
                strengthText.innerText = 'متوسطة (أضف رموزاً لتكون أقوى)';
                strengthText.className = 'text-warning d-block mt-1 ps-1 fw-bold';
            } else {
                strengthMeter.className = 'progress-bar bg-success transition-all';
                strengthText.innerText = 'قوية وممتازة ✅';
                strengthText.className = 'text-success d-block mt-1 ps-1 fw-bold';
            }
        });

        // ==========================================
        // 5. التحقق الفوري من تطابق كلمات المرور
        // ==========================================
        function checkPasswordsMatch() {
            if (!isEditMode && confirmPasswordInput.value.length > 0) {
                if (confirmPasswordInput.value === passwordInput.value) {
                    matchError.classList.add('d-none');
                    confirmPasswordInput.classList.remove('is-invalid');
                    confirmPasswordInput.classList.add('is-valid');
                    return true;
                } else {
                    matchError.classList.remove('d-none');
                    confirmPasswordInput.classList.remove('is-valid');
                    confirmPasswordInput.classList.add('is-invalid');
                    return false;
                }
            }
            return true;
        }
        
        passwordInput.addEventListener('input', checkPasswordsMatch);
        confirmPasswordInput.addEventListener('input', checkPasswordsMatch);

        // ==========================================
        // 6. قلب النظام: الإرسال عبر AJAX مع تحديد الخطأ الذكي
        // ==========================================
        userForm.addEventListener('submit', async function(e) {
            e.preventDefault(); 
            
            // إزالة أي تنبيهات سابقة
            userForm.querySelectorAll('.is-invalid').forEach(el => el.classList.remove('is-invalid'));

            // التحقق من صحة حقول HTML5
            if (!userForm.checkValidity()) {
                userForm.classList.add('was-validated');
                return;
            }

            // تحقق الباسورد في وضع الإضافة
            if (!isEditMode) {
                if (passwordInput.value.length < 8) {
                    passwordInput.classList.add('is-invalid');
                    Swal.fire('تنبيه', 'كلمة المرور قصيرة جداً، يجب أن تكون 8 أحرف على الأقل.', 'warning');
                    return;
                }
                if (!checkPasswordsMatch()) return;
            }
            
            // تجميد الزر لمنع الضغط المزدوج
            submitBtn.classList.add('btn-loading');
            submitBtn.disabled = true;

            try {
                const formData = new FormData(userForm);
                const data = Object.fromEntries(formData);

                const response = await fetch(userForm.action, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await response.json();

                if (!response.ok || !result.success) {
                    // ❌ فشل العملية: إعادة تفعيل الزر وتحديد حقل الخطأ بذكاء
                    submitBtn.classList.remove('btn-loading');
                    submitBtn.disabled = false;

                    // الذكاء الاصطناعي لتوجيه المستخدم للخطأ:
                    if (result.message.includes('اسم المستخدم')) {
                        usernameInput.classList.add('is-invalid');
                        usernameInput.focus();
                    } else if (result.message.includes('هذا الاسم مسجل')) {
                        nameInput.classList.add('is-invalid');
                        nameInput.focus();
                    }

                    Swal.fire({
                        title: 'تنبيه من النظام',
                        text: result.message,
                        icon: 'error',
                        confirmButtonColor: '#ef4444',
                        confirmButtonText: 'تعديل البيانات',
                        customClass: { confirmButton: 'rounded-pill px-4 fw-bold' }
                    });
                } else {
                    // ✅ نجاح العملية
                    userModal.hide(); // إغلاق النافذة بنعومة
                    Swal.fire({
                        title: 'عملية ناجحة',
                        text: result.message,
                        icon: 'success',
                        timer: 1500,
                        showConfirmButton: false
                    }).then(() => {
                        window.location.reload(); // تحديث الجدول
                    });
                }
            } catch (error) {
                submitBtn.classList.remove('btn-loading');
                submitBtn.disabled = false;
                Swal.fire('خطأ بالشبكة', 'تعذر الاتصال بالخادم، يرجى التأكد من اتصالك بالإنترنت.', 'error');
            }
        });

        // ==========================================
        // 7. تهيئة النافذة للوضع الافتراضي (الإضافة)
        // ==========================================
        window.resetUserForm = function() {
            isEditMode = false;
            userForm.action = '/admin/users/create';
            userForm.reset();
            userForm.classList.remove('was-validated');
            userForm.querySelectorAll('.is-invalid, .is-valid').forEach(el => el.classList.remove('is-invalid', 'is-valid'));
            
            modalTitleText.innerText = 'إضافة مستخدم جديد';
            modalIcon.className = 'fa-solid fa-user-plus';
            submitBtn.querySelector('.btn-text').innerHTML = 'إنشاء الحساب <i class="fa-solid fa-check ms-1"></i>';
            
            usernameInput.readOnly = false;
            usernameInput.classList.remove('bg-secondary', 'bg-opacity-10');
            nameInput.readOnly = false;
            nameInput.classList.remove('bg-secondary', 'bg-opacity-10');
            
            passwordInput.required = true;
            confirmPasswordInput.required = true;
            passwordSection.classList.remove('d-none');
            passwordHelp.classList.add('d-none');
            
            strengthMeter.style.width = '0%';
            strengthText.innerText = '8 أحرف على الأقل';
            matchError.classList.add('d-none');
            
            // إعادة أيقونات العين لحالتها الطبيعية
            document.getElementById('togglePass').className = 'fa-regular fa-eye password-toggle';
            document.getElementById('toggleConfirmPass').className = 'fa-regular fa-eye password-toggle';
            passwordInput.type = 'password';
            confirmPasswordInput.type = 'password';
        };

        // ==========================================
        // 8. تهيئة النافذة لوضع التعديل (Edit Mode)
        // ==========================================
        window.editUser = function(id, name, username, role) {
            resetUserForm(); // تنظيف النافذة أولاً
            isEditMode = true;
            
            userForm.action = `/admin/users/update/${id}`;
            nameInput.value = name;
            usernameInput.value = username;
            roleInput.value = role;
            
            modalTitleText.innerText = 'تعديل بيانات الصلاحية';
            modalIcon.className = 'fa-solid fa-user-pen';
            submitBtn.querySelector('.btn-text').innerHTML = 'حفظ التعديلات <i class="fa-solid fa-arrows-rotate ms-1"></i>';
            
            // قفل الخصائص الحساسة أمنياً وتلوينها كدليل بصري
            usernameInput.readOnly = true;
            usernameInput.classList.add('bg-secondary', 'bg-opacity-10');
            // فتحنا حقل الاسم للتعديل، الخادم سيفلتره بذكاء
            
            passwordInput.required = false;
            confirmPasswordInput.required = false;
            passwordSection.classList.add('d-none'); 
            passwordHelp.classList.remove('d-none'); 
            
            userModal.show();
        };

        // ==========================================
        // 9. تأكيد الحذف عبر الـ AJAX
        // ==========================================
        window.confirmDelete = function(id) {
            Swal.fire({
                title: 'هل أنت متأكد؟',
                text: 'لن تتمكن من استعادة هذا الحساب بعد الحذف.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#cbd5e1',
                confirmButtonText: 'نعم، احذف نهائياً',
                cancelButtonText: 'تراجع',
                reverseButtons: true, 
                customClass: { 
                    confirmButton: 'rounded-pill px-4 fw-bold shadow-sm', 
                    cancelButton: 'rounded-pill px-4 fw-bold text-dark' 
                }
            }).then(async (result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'جاري الحذف...',
                        allowOutsideClick: false,
                        showConfirmButton: false,
                        didOpen: () => { Swal.showLoading(); }
                    });
                    
                    try {
                        const response = await fetch(`/admin/users/delete/${id}`, { method: 'GET' });
                        const data = await response.json();
                        
                        if (response.ok && data.success) {
                            Swal.fire({ icon: 'success', title: 'تم الحذف', timer: 1500, showConfirmButton: false })
                                .then(() => window.location.reload());
                        } else {
                            Swal.fire('تنبيه', data.message, 'warning');
                        }
                    } catch (error) {
                        Swal.fire('خطأ بالشبكة', 'فشل الاتصال بالخادم.', 'error');
                    }
                }
            });
        };
    });
</script>

